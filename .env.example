# Supabase (required) — Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (required for password reset and email verification) — Project Settings → API → service_role
# Never expose this key in client-side code or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (optional) — auth email redirects fallback when request headers are unavailable
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP (required for password reset and email verification emails)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
# Set to true for port 465; leave empty/false for STARTTLS on 587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Vodora
