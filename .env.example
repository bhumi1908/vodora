# Supabase (required) — Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth: email confirmation is enabled (see supabase/config.toml).
# After signup, users land on /verify-email and must click the link in their inbox.
# After verifying, they are redirected to /login to sign in.
#
# Supabase Dashboard setup (hosted project):
#   1. Authentication → Providers → Email → enable "Confirm email"
#   2. Authentication → URL Configuration → add redirect URL:
#        http://localhost:3000/auth/callback  (and your production URL)
#   3. Authentication → Email Templates → Confirm signup:
#        copy HTML from supabase/templates/confirmation.html
#   4. Built-in Supabase email is limited to ~2 emails/hour — avoid repeated resends in dev.
#
# Local Supabase: run `npx supabase start` and use Inbucket at http://127.0.0.1:54324
